# ── Local development (SQLite) ──
DATABASE_URL="file:./dev.db"

# ── Vercel production (Turso — free tier) ──
# Turso 대시보드에서 DB 생성 후 아래 값을 Vercel Environment Variables에 등록
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="eyJhbG..."
# migrate deploy용 (authToken 포함 URL)
# DATABASE_URL="libsql://your-db-name.turso.io?authToken=eyJhbG..."

# ── Auth (필수) ──
# Vercel에서 32자 이상 랜덤 문자열로 설정 (openssl rand -base64 32)
AUTH_SECRET="change-me-in-production-use-long-random-string"

# ── Push notifications (선택) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@haengbok-daycare.local"
